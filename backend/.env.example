# Server
PORT=5000
NODE_ENV=development

# HuggingFace API
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
# HF_TOKEN=your_hf_token_here

# Text Generation Models
# Recommended for current Hugging Face Inference Providers routes
TEXT_MODEL=meta-llama/Llama-3.1-8B-Instruct
CODE_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct

# Image Generation Models
IMAGE_MODEL=black-forest-labs/FLUX.1-schnell
IMAGE_EDIT_MODEL=black-forest-labs/FLUX.1-Kontext-dev
VISION_MODEL=HuggingFaceTB/SmolVLM-Instruct

# Web Search (optional - implement Serper API or similar)
WEB_SEARCH_API_KEY=your_web_search_api_key

# Database
DB_PATH=./data/megpt.db
